# ============================================================
# SkyPulse Weather App — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Or set DEMO_MODE=true to run with zero API keys!

# --- Demo Mode ---
# Set to "true" to run without any API keys (uses realistic mock data)
DEMO_MODE=true

# --- Flask (REQUIRED) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=CHANGE_ME
FLASK_DEBUG=true

# --- CORS ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# --- Contact Email ---
# Used in User-Agent headers for third-party API requests (Nominatim)
CONTACT_EMAIL=your_email@example.com

# --- OpenWeatherMap ---
# Sign up: https://home.openweathermap.org/users/sign_up
# Free tier: 60 calls/min, 1M calls/month
OPENWEATHERMAP_API_KEY=your_key_here

# --- YouTube Data API v3 ---
# Sign up: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in your project
# Free tier: 10,000 units/day
YOUTUBE_API_KEY=your_key_here

# --- Unsplash (YouTube fallback) ---
# Sign up: https://unsplash.com/developers
# Free tier: 50 requests/hour
UNSPLASH_ACCESS_KEY=your_key_here

# --- Anthropic Claude API ---
# Sign up: https://console.anthropic.com/
# Model used: claude-sonnet-4-6
ANTHROPIC_API_KEY=your_key_here

# --- Frontend (Vite) ---
# Used for weather map tile overlay (same as OPENWEATHERMAP_API_KEY)
# Prefix with VITE_ so Vite exposes it to the browser
VITE_OWM_TILE_KEY=your_key_here
